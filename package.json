{
    "name": "@titanpl/surface",
    "version": "1.0.2",
    "description": "Surface is an ultra-optimized high level modules provider native extension for the TitanPl framework, built entirely in Go. It handles data-heavy, IO-bound, and system-level tasks outside the JavaScript runtime to ensure sub-millisecond response times and rock-solid stability.",
    "main": "index.js",
    "type": "module",
    "types": "index.d.ts",
    "scripts": {
        "build:native": "go build -buildmode=c-shared -o surface.dll"
    },
    "keywords": [
        "titan",
        "titanpl",
        "titan-planet",
        "extension",
        "csv",
        "json",
        "mail",
        "smtp",
        "seo",
        "seo extraction",
        "clean"
    ],
    "author": "ezetgalaxy",
    "license": "ISC",
    "files": [
        "index.js",
        "titan.json",
        "utils",
        "lib",
        "index.d.ts",
        "*.h",
        "*.dll",
        "*.exe",
        "*.so",
        "*.dylib",
        "README.md"
    ],
    "devDependencies": {
        "esbuild": "^0.27.2"
    },
    "dependencies": {
        "@titanpl/core": "4.0.0",
        "@titanpl/native": "^7.0.1"
    }
}
